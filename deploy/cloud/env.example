# Chronos Command — cloud / online UAT
# Copy to repo root as .env before: docker compose up -d --build

# REQUIRED — long random string (openssl rand -hex 32)
SCHEDULER_STORAGE_SECRET=change-me-to-64-hex-chars

# Public URL testers use (https preferred)
SCHEDULER_PUBLIC_URL=https://chronos-uat.example.com

# App port inside / mapped by compose
SCHEDULER_PORT=8080

# Domain for Caddy TLS (must match DNS A record)
CHRONOS_DOMAIN=chronos-uat.example.com

# Skip slow startup gates on server boot
SCHEDULER_SKIP_STARTUP_GATES=1

# Optional lab isolation
# SCHEDULER_DB_PATH=/app/persist/virtual_uat.db
# SCHEDULER_TENANT_ID=uat-agency
# SCHEDULER_TENANT_NAME=UAT Agency PD
